# =============================================================================
# Promoly Core — modelo de variáveis de ambiente
# Copie para .env e preencha. NÃO comite o .env real (gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
ENVIRONMENT=production          # production | development
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:port/dbname

# -----------------------------------------------------------------------------
# Segurança / API
# -----------------------------------------------------------------------------
API_KEY=

# -----------------------------------------------------------------------------
# Scraper (Mercado Livre)
# -----------------------------------------------------------------------------
URL_MLB_BASE=https://www.mercadolivre.com.br
URL_MLB_SEARCH_BASE=https://lista.mercadolivre.com.br
SCRAPER_ENABLED_CATEGORIES=games,automotivo,iluminacao,fitness,limpeza,informatica

# -----------------------------------------------------------------------------
# Twitter / X (legado)
# -----------------------------------------------------------------------------
X_PASSWORD=

# -----------------------------------------------------------------------------
# Instagram (Graph API — graph.instagram.com)
# Token longo (60d): obter via OAuth Instagram Business Login.
# SITE_BASE_URL: base pública onde data/instagram/ é servido.
# -----------------------------------------------------------------------------
IG_ACCESS_TOKEN=
IG_USER_ID=
SITE_BASE_URL=https://seu-dominio.com

# -----------------------------------------------------------------------------
# Frontend (build)
# -----------------------------------------------------------------------------
VITE_API_URL=https://seu-dominio.com
