# Template de variáveis de ambiente. Copie para .env e preencha.
# NÃO commitar o .env real (já está no .gitignore).

# Ambiente: production | development
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Banco PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/promoly

# Scraper MLB
SCRAPER_ENABLED_CATEGORIES=
URL_MLB_BASE=https://www.mercadolivre.com.br
URL_MLB_SEARCH_BASE=https://lista.mercadolivre.com.br

# Frontend (Next.js / Vercel)
VITE_API_URL=http://localhost:8080

# Chave da API para rotas sensíveis (/twitter/*).
# Gere com: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
API_KEY=changeme-generate-a-strong-key

# Rate-limit dos redirects (opcional; defaults: 60 / 60s)
REDIRECT_RATE_LIMIT=60
REDIRECT_RATE_WINDOW=60

# Twitter / X
X_PASSWORD=
